#!/bin/sh
set -e

if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-remove" ]; then
  if command -v systemctl >/dev/null 2>&1; then
    TARGET_USER="${SUDO_USER:-$USER}"
    if [ -n "$TARGET_USER" ] && [ "$TARGET_USER" != "root" ]; then
      su - "$TARGET_USER" -c "systemctl --user daemon-reload && systemctl --user enable --now print.it.service" 2>/dev/null || true
    fi
  fi
fi

echo ""
echo "print.it instalado."
echo "Configure a impressora no sistema de gestao."

exit 0
